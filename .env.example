# WhatsApp Cloud API
WHATSAPP_TOKEN=          # Meta permanent system user token (EAA...) — never expires
WHATSAPP_PHONE_ID=       # From Meta API Setup page (e.g. 1199517913234373)
WEBHOOK_VERIFY_TOKEN=    # Any secret string — used for Meta webhook handshake

# Anthropic
ANTHROPIC_API_KEY=       # sk-ant-...

# Database
# Local:   file:./kilimanjaro.db
# Railway: file:/data/kilimanjaro.db  (volume mounted at /data)
DATABASE_URL=file:./kilimanjaro.db

# Server (Railway injects PORT automatically — leave unset in Railway Variables)
PORT=3000
NODE_ENV=development

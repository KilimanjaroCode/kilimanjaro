# WhatsApp Cloud API
WHATSAPP_TOKEN=          # Meta System User access token (EAA...)
WHATSAPP_PHONE_ID=       # Meta phone number ID
WEBHOOK_VERIFY_TOKEN=    # Any string you choose — used to verify webhook with Meta

# Anthropic
ANTHROPIC_API_KEY=       # sk-ant-...

# Database (Phase 2)
DATABASE_URL=file:./kilimanjaro.db

# Server
PORT=3000
NODE_ENV=development

// Kilimanjaro — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  phoneNumber String     @unique
  createdAt   DateTime   @default(now())
  messages    Message[]
  notes       Note[]
  reminders   Reminder[]
  invoices    Invoice[]
}

model Message {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Note {
  id        Int      @id @default(autoincrement())
  userId    Int
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Reminder {
  id        Int       @id @default(autoincrement())
  userId    Int
  text      String
  fireAt    DateTime
  active    Boolean   @default(true)
  firedAt   DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Invoice {
  id          Int      @id @default(autoincrement())
  userId      Int
  client      String
  amount      String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
